{
  "manifest_version": 3,
  "name": "PromptShield",
  "version": "1.0.0",
  "description": "DLP Gateway - redacts sensitive data before it reaches cloud LLMs",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://copilot.microsoft.com/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://copilot.microsoft.com/*"
      ],
      "js": [
        "utils/constants.js",
        "parser/regexPatterns.js",
        "parser/nerChecker.js",
        "parser/astParser.js",
        "parser/parser.js",
        "content/observer.js",
        "content/toast.js",
        "content/injector.js",
        "content/interceptor.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
