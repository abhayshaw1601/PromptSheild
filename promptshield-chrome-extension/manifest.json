{
  "manifest_version": 3,
  "name": "PromptShield",
  "version": "1.0.0",
  "description": "DLP Gateway - redacts sensitive data before it reaches cloud LLMs",
  "permissions": ["activeTab", "scripting", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "PromptShield",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://copilot.microsoft.com/*",
    "https://claude.ai/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/icon48.png", "icons/icon128.png"],
      "matches": [
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://copilot.microsoft.com/*",
        "https://claude.ai/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://copilot.microsoft.com/*",
        "https://claude.ai/*"
      ],
      "js": [
        "utils/constants.js",
        "utils/masker.js",
        "parser/regexPatterns.js",
        "parser/nerChecker.js",
        "parser/astParser.js",
        "parser/parser.js",
        "content/observer.js",
        "content/toast.js",
        "content/badge.js",
        "content/injector.js",
        "content/interceptor.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
